# BTEB Results Zone — Environment Variables
# Copy this to .env.local and fill in your values.

# ---- Google AdSense ----
# Your AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX).
# Get it from https://www.google.com/adsense/ -> Account -> Account information.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-1119994195656037

# Ad unit slot IDs as JSON. Create ad units in your AdSense dashboard,
# then map each named slot to its ID:
#   "home-inline"      -> ad on the home page (above features)
#   "individual-inline"-> ad on the individual results page (above result)
#   "sidebar"          -> sidebar ad (if you add one)
NEXT_PUBLIC_ADSENSE_SLOTS={"home-inline":"1234567890","individual-inline":"2345678901","sidebar":"3456789012"}

# ---- Database (Prisma) ----
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ---- Optional: official BTEB archive override ----
# The scraper hits http://180.211.162.102:8444/result_arch/ by default.
# Override here if BTEB moves the archive:
# BTEB_ARCHIVE_URL=http://180.211.162.102:8444/result_arch/result.php
